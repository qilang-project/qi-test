// 假模型服务器 — OpenAI 兼容的「假 LLM」，返回脚本化回合，用来确定性地测 agent 循环。
//
// 真 LLM 走 FFI 打 HTTP，没法在单进程里 mock。所以起一个 qi-web 假服务器：
// 把 QI_LLM_BASE 指到它，agent 的每次 /chat/completions 就拿到脚本里的下一条回合。
//
// 脚本 = 环境变量 QI_FAKE_SCRIPT，每行一个回合（按请求顺序消费，用尽则重复最后一条）：
//   工具|<工具名>|<参数JSON>     → 让模型「调用某工具」（一条 tool_call）
//   文本|<答复文本>              → 让模型「给最终文本答复」
//   回显|                        → 把收到的请求体原样当最终答复（断言提示词注入用）
// 例（两回合：先调查天气工具，再给最终答复）：
//   export QI_FAKE_SCRIPT=$'工具|查天气|{"city":"Tokyo"}\n文本|东京现在18度，晴。'
// 端口 = QI_FAKE_PORT（默认 41877），仅监听 127.0.0.1。注：参数JSON/文本里别含 `|` 或换行。

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.列表 作为 列表库;
导入 Web::{
    应用, 上下文, 响应,
    创建应用, 配置, 提交, 获取,
    请求主体, 返回文本, 设置响应头,
    运行应用
};

变量 脚本: 整数 = 0;    // 字符串列表：每行一个回合
变量 行数: 整数 = 0;
变量 游标: 整数 = 0;

// JSON 字符串值转义
函数 转义(s: 字符串) : 字符串 {
    变量 t: 字符串 = 字符串::替换(s, "\\", "\\\\");
    t = 字符串::替换(t, "\"", "\\\"");
    t = 字符串::替换(t, "\n", "\\n");
    t = 字符串::替换(t, "\r", "\\r");
    t = 字符串::替换(t, "\t", "\\t");
    返回 t;
}

// 构造「调用工具」的 OpenAI 响应（content=null + 一条 tool_call）
函数 工具响应(工具名: 字符串, 参数: 字符串) : 字符串 {
    返回 "{\"id\":\"fake\",\"object\":\"chat.completion\",\"choices\":[{\"index\":0,\"message\":{\"role\":\"assistant\",\"content\":null,\"tool_calls\":[{\"id\":\"call_1\",\"type\":\"function\",\"function\":{\"name\":\""
        + 工具名 + "\",\"arguments\":\"" + 转义(参数) + "\"}}]},\"finish_reason\":\"tool_calls\"}]}";
}

// 构造「最终文本答复」的 OpenAI 响应
函数 文本响应(文本: 字符串) : 字符串 {
    返回 "{\"id\":\"fake\",\"object\":\"chat.completion\",\"choices\":[{\"index\":0,\"message\":{\"role\":\"assistant\",\"content\":\""
        + 转义(文本) + "\"},\"finish_reason\":\"stop\"}]}";
}

// 把一行脚本（工具|名|参 或 文本|内容）翻译成 OpenAI 响应体
函数 渲染回合(行: 字符串) : 字符串 {
    变量 段: 整数 = 字符串::分割(行, "|");
    变量 n: 整数 = 列表库::字符串列表大小(段);
    如果 (n == 0) { 返回 文本响应("(空回合)"); }
    变量 种类: 字符串 = 列表库::获取字符串(段, 0);
    如果 (字符串::等于(种类, "工具") == 1 与 n >= 3) {
        返回 工具响应(列表库::获取字符串(段, 1), 列表库::获取字符串(段, 2));
    }
    如果 (字符串::等于(种类, "文本") == 1 与 n >= 2) {
        返回 文本响应(列表库::获取字符串(段, 1));
    }
    返回 文本响应("(无法识别的回合: " + 行 + ")");
}

// POST /chat/completions —— 返回脚本里的下一条回合
函数 处理补全(上下文值: 上下文) : 响应 {
    变量 体请求: 字符串 = 请求主体(上下文值);
    变量 idx: 整数 = 游标;
    如果 (idx >= 行数) { idx = 行数 - 1; }     // 用尽则重复最后一条
    游标 = 游标 + 1;
    变量 体: 字符串 = "{\"choices\":[]}";
    如果 (idx >= 0) {
        变量 行值: 字符串 = 列表库::获取字符串(脚本, idx);
        如果 (字符串::开始于(行值, "回显") == 1) {
            体 = 文本响应(体请求);   // 请求体原样回显 —— 测试可断言提示词里注入了什么
        } 否则 {
            体 = 渲染回合(行值);
        }
    }
    返回 设置响应头(返回文本(上下文值, 体), "Content-Type", "application/json");
}

// GET / —— 健康检查（不消费脚本游标，给就绪探测用）
函数 处理健康(上下文值: 上下文) : 响应 {
    返回 返回文本(上下文值, "ok");
}

函数 入口() {
    变量 脚本文本: 字符串 = 系统.获取环境变量("QI_FAKE_SCRIPT");
    脚本 = 字符串::分割(脚本文本, "\n");
    行数 = 列表库::字符串列表大小(脚本);

    变量 端口文本: 字符串 = 系统.获取环境变量("QI_FAKE_PORT");
    变量 端口: 整数 = 41877;
    如果 (字符串::字节长度(端口文本) > 0) { 端口 = 字符串转整数(端口文本); }

    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, "127.0.0.1", 端口);
    应用值 = 获取(应用值, "/", 处理健康);
    应用值 = 提交(应用值, "/chat/completions", 处理补全);
    IO.打印行("假模型就绪 127.0.0.1:" + 整数转字符串(端口) + " 回合数=" + 整数转字符串(行数));
    运行应用(应用值);
}
