// 并发派发_测 — Harness 工具::并发派发（本地并发，无 LLM）

包 主程序;

导入 测试::{运行用例, 摘要并退出, 断言包含, 断言为真};
导入 标准库.列表 作为 列表库;
导入 标准库.时间;
导入 Harness::{工具, 创建注册表, 注册, 并发派发};
导入 Harness.追踪 作为 追踪;

函数 慢工具甲(参数JSON: 字符串) : 字符串 { 时间.睡眠毫秒(300); 返回 "{\"tool\":\"甲\",\"value\":111}"; }
函数 慢工具乙(参数JSON: 字符串) : 字符串 { 时间.睡眠毫秒(300); 返回 "{\"tool\":\"乙\",\"value\":222}"; }
函数 慢工具丙(参数JSON: 字符串) : 字符串 { 时间.睡眠毫秒(300); 返回 "{\"tool\":\"丙\",\"value\":333}"; }

// 共享：建表 + 跑一次并发派发，回填全局结果供两个用例查
变量 _结果表: 整数 = 0;
变量 _耗时: 整数 = 0;

函数 _跑一次() {
    追踪.禁用();
    变量 表: 整数 = 创建注册表();
    表 = 注册(表, 0, (工具 { 名字: "慢工具甲", 描述: "甲", 参数schema: "{}", 处理: 慢工具甲 }));
    表 = 注册(表, 0, (工具 { 名字: "慢工具乙", 描述: "乙", 参数schema: "{}", 处理: 慢工具乙 }));
    表 = 注册(表, 0, (工具 { 名字: "慢工具丙", 描述: "丙", 参数schema: "{}", 处理: 慢工具丙 }));
    变量 名表: 整数 = 列表库::创建字符串列表();
    列表库::添加字符串(名表, "慢工具甲");
    列表库::添加字符串(名表, "慢工具乙");
    列表库::添加字符串(名表, "慢工具丙");
    变量 参表: 整数 = 列表库::创建字符串列表();
    列表库::添加字符串(参表, "{}");
    列表库::添加字符串(参表, "{}");
    列表库::添加字符串(参表, "{}");
    变量 起: 整数 = 时间.当前毫秒();
    _结果表 = 并发派发(表, 名表, 参表, 3);
    _耗时 = 时间.当前毫秒() - 起;
}

函数 测_结果对齐() : 整数 {
    断言包含(列表库::获取字符串(_结果表, 0), "111", "结果[0] = 甲(111)");
    断言包含(列表库::获取字符串(_结果表, 1), "222", "结果[1] = 乙(222)");
    断言包含(列表库::获取字符串(_结果表, 2), "333", "结果[2] = 丙(333)");
    返回 0;
}

函数 测_并发计时() : 整数 {
    变量 快: 整数 = 0;
    如果 (_耗时 < 600) { 快 = 1; }   // 3×300ms 串行约 900ms；并发应 ≈300ms
    断言为真(快, "并发耗时 <600ms（非串行）");
    返回 0;
}

函数 入口() {
    _跑一次();
    运行用例("并发派发.结果对齐", 测_结果对齐);
    运行用例("并发派发.并发计时", 测_并发计时);
    摘要并退出();
}
