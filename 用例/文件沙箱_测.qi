// 文件沙箱_测 — Harness 文件工具 沙箱/权限安全（无 LLM，确定性，自带 fixture）

包 主程序;

导入 测试::{运行用例, 摘要并退出, 断言为真, 断言包含};
导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 Harness::{创建代理};
导入 Harness.工具::{派发};
导入 Harness.文件工具::{文件沙箱, 创建文件沙箱, 允许写, 装备文件工具};

// 断言某次派发「被拒绝」（含越界 / 无此权限 / unknown_tool 任一标记）
函数 _拒(代理值: 代理, 工具名: 字符串, 参数: 字符串, 说明: 字符串) {
    变量 r: 字符串 = 派发(代理值.工具表, 工具名, 参数);
    变量 拒: 整数 = 0;
    如果 (字符串::包含(r, "越界") == 1 或 字符串::包含(r, "无此权限") == 1 或 字符串::包含(r, "unknown_tool") == 1) {
        拒 = 1;
    }
    断言为真(拒, 说明);
}

函数 测_拒越界路径() : 整数 {
    变量 a: 代理 = 装备文件工具(创建代理("t", 0), 允许写(创建文件沙箱("/tmp/qi测试沙箱")));
    _拒(a, "读文件", "{\"路径\":\"/etc/passwd\"}", "绝对路径 /etc/passwd");
    _拒(a, "读文件", "{\"路径\":\"../../../etc/passwd\"}", ".. 穿越到 /etc");
    _拒(a, "读文件", "{\"路径\":\"notes/../../etc/passwd\"}", "夹层 .. 穿越");
    _拒(a, "读文件", "{\"路径\":\"~/.ssh/id_rsa\"}", "家目录 ~ 展开");
    _拒(a, "写文件", "{\"路径\":\"/tmp/外部.txt\",\"内容\":\"x\"}", "绝对路径写出沙箱");
    返回 0;
}

函数 测_拒符号链接逃逸() : 整数 {
    IO.创建目录("/tmp/qi测试沙箱");
    IO.创建符号链接("/etc", "/tmp/qi测试沙箱/逃逸链接");   // 自带 fixture：沙箱内放一条指向 /etc 的逃逸链接
    变量 a: 代理 = 装备文件工具(创建代理("t", 0), 允许写(创建文件沙箱("/tmp/qi测试沙箱")));
    _拒(a, "读文件", "{\"路径\":\"逃逸链接/passwd\"}", "经符号链接读 /etc/passwd");
    返回 0;
}

函数 测_放行正常路径() : 整数 {
    变量 a: 代理 = 装备文件工具(创建代理("t", 0), 允许写(创建文件沙箱("/tmp/qi测试沙箱")));
    断言包含(派发(a.工具表, "写文件", "{\"路径\":\"子目录/笔记.txt\",\"内容\":\"沙箱内合法内容\"}"), "ok", "写入沙箱内文件");
    断言包含(派发(a.工具表, "读文件", "{\"路径\":\"子目录/笔记.txt\"}"), "沙箱内合法内容", "读回刚写的内容");
    返回 0;
}

函数 测_只读不暴露写删工具() : 整数 {
    变量 a: 代理 = 装备文件工具(创建代理("只读", 0), 创建文件沙箱("/tmp/qi测试沙箱只读"));
    _拒(a, "写文件", "{\"路径\":\"a.txt\",\"内容\":\"x\"}", "只读沙箱无「写文件」工具");
    _拒(a, "删除文件", "{\"路径\":\"a.txt\"}", "只读沙箱无「删除文件」工具");
    返回 0;
}

函数 入口() {
    运行用例("文件沙箱.拒越界路径", 测_拒越界路径);
    运行用例("文件沙箱.拒符号链接逃逸", 测_拒符号链接逃逸);
    运行用例("文件沙箱.放行正常路径", 测_放行正常路径);
    运行用例("文件沙箱.只读权限门控", 测_只读不暴露写删工具);
    摘要并退出();
}
