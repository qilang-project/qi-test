// 桩_测 — stub/spy 自测（无 LLM）

包 主程序;

导入 测试::{运行用例, 摘要并退出, 断言相等整数, 断言包含, 新桩, 桩设返回, 桩取处理, 桩调用次数, 桩末次参数, 桩重置};
导入 Harness::{工具, 创建注册表, 注册, 派发};

函数 测_stub返回预设值() : 整数 {
    变量 s: 整数 = 新桩();
    桩设返回(s, "{\"temp\":18}");
    变量 h: 函数(字符串):字符串 = 桩取处理(s);
    变量 表: 整数 = 创建注册表();
    表 = 注册(表, 0, (工具 { 名字: "查天气", 描述: "", 参数schema: "{}", 处理: h }));
    变量 r: 字符串 = 派发(表, "查天气", "{\"city\":\"Tokyo\"}");
    断言包含(r, "18", "派发返回桩的预设值");
    返回 0;
}

函数 测_spy计数与末参() : 整数 {
    变量 s: 整数 = 新桩();
    桩设返回(s, "{}");
    变量 h: 函数(字符串):字符串 = 桩取处理(s);
    变量 表: 整数 = 创建注册表();
    表 = 注册(表, 0, (工具 { 名字: "f", 描述: "", 参数schema: "{}", 处理: h }));
    变量 a: 字符串 = 派发(表, "f", "{\"x\":1}");
    变量 b: 字符串 = 派发(表, "f", "{\"city\":\"Beijing\"}");
    断言相等整数(桩调用次数(s), 2, "被调用 2 次");
    断言包含(桩末次参数(s), "Beijing", "记录末次参数");
    返回 0;
}

函数 测_多桩互不串台() : 整数 {
    变量 甲: 整数 = 新桩();
    变量 乙: 整数 = 新桩();
    桩设返回(甲, "{\"who\":\"甲\"}");
    桩设返回(乙, "{\"who\":\"乙\"}");
    变量 h甲: 函数(字符串):字符串 = 桩取处理(甲);
    变量 h乙: 函数(字符串):字符串 = 桩取处理(乙);
    变量 表: 整数 = 创建注册表();
    表 = 注册(表, 0, (工具 { 名字: "甲工具", 描述: "", 参数schema: "{}", 处理: h甲 }));
    表 = 注册(表, 0, (工具 { 名字: "乙工具", 描述: "", 参数schema: "{}", 处理: h乙 }));
    变量 r甲: 字符串 = 派发(表, "甲工具", "{}");
    断言包含(r甲, "甲", "甲桩返回自己的值");
    断言相等整数(桩调用次数(甲), 1, "甲桩计数=1");
    断言相等整数(桩调用次数(乙), 0, "乙桩未被调用（未串台）");
    返回 0;
}

函数 测_桩重置() : 整数 {
    变量 s: 整数 = 新桩();
    变量 h: 函数(字符串):字符串 = 桩取处理(s);
    变量 表: 整数 = 创建注册表();
    表 = 注册(表, 0, (工具 { 名字: "g", 描述: "", 参数schema: "{}", 处理: h }));
    变量 r: 字符串 = 派发(表, "g", "{}");
    桩重置(s);
    断言相等整数(桩调用次数(s), 0, "重置后计数归零");
    返回 0;
}

函数 入口() {
    运行用例("桩.stub返回值", 测_stub返回预设值);
    运行用例("桩.spy计数与末参", 测_spy计数与末参);
    运行用例("桩.多桩互不串台", 测_多桩互不串台);
    运行用例("桩.重置", 测_桩重置);
    摘要并退出();
}
