// 结构化_测 — Harness 校验JSON对象（结构化输出基础原语，纯函数，无 LLM）

包 主程序;

导入 测试::{运行用例, 摘要并退出, 断言相等整数};
导入 标准库.列表 作为 列表库;
导入 Harness::{校验JSON对象};

函数 _必需字段() : 整数 {
    变量 必需: 整数 = 列表库::创建字符串列表();
    列表库::添加字符串(必需, "name");
    列表库::添加字符串(必需, "age");
    返回 必需;
}

函数 测_字段齐全() : 整数 {
    断言相等整数(校验JSON对象("{\"name\":\"张三\",\"age\":30}", _必需字段()), 1, "合法且字段齐 → 1");
    返回 0;
}

函数 测_缺字段() : 整数 {
    断言相等整数(校验JSON对象("{\"name\":\"李四\"}", _必需字段()), 0, "合法但缺 age → 0");
    返回 0;
}

函数 测_非法JSON() : 整数 {
    断言相等整数(校验JSON对象("这不是 JSON {{{", _必需字段()), 0, "非法 JSON → 0");
    返回 0;
}

函数 入口() {
    运行用例("结构化.字段齐全", 测_字段齐全);
    运行用例("结构化.缺字段", 测_缺字段);
    运行用例("结构化.非法JSON", 测_非法JSON);
    摘要并退出();
}
