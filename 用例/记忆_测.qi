// 记忆_测 — Harness 记忆模块（SQLite 长期记忆，纯离线，不碰 LLM）
//
// 覆盖：建库/三类型记住/回忆命中与重要度排序/不命中返回空/遗忘/
//       重开库持久化/SQL 注入毒串（单引号）存取无损。

包 主程序;

导入 测试::{运行用例, 摘要并退出, 断言为真, 断言相等整数, 断言包含, 断言不含};
导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 Harness.记忆::{打开记忆, 记住, 回忆, 遗忘, 记忆条数, 关闭记忆};

常量 库路径 = "/tmp/qi记忆测试.db";

// 每个用例从干净库开始（删掉上轮/上个用例的残留文件）
函数 _新库() : 整数 {
    如果 (IO.文件存在(库路径) == 1) { IO.删除文件(库路径); }
    返回 打开记忆(库路径);
}

// 比较结果转整数（断言为真 收 整数，比较表达式直接传参是 i1 类型不匹配）
函数 _大于(a: 整数, b: 整数) : 整数 {
    如果 (a > b) { 返回 1; }
    返回 0;
}

函数 测_建库与三类型记住() : 整数 {
    变量 库: 整数 = _新库();
    断言为真(_大于(库, 0), "打开记忆返回有效句柄");
    变量 id1: 整数 = 记住(库, "事实", "用户在深圳工作", "用户,深圳,工作", 4);
    变量 id2: 整数 = 记住(库, "经验", "部署前先跑冒烟测试能避免回滚", "部署,冒烟,回滚", 5);
    变量 id3: 整数 = 记住(库, "偏好", "用户喜欢简短的中文回答", "回答,风格,简短", 3);
    断言为真(_大于(id1, 0), "记住 事实 返回 id");
    断言为真(_大于(id2, id1), "id 自增");
    断言为真(_大于(id3, id2), "id 继续自增");
    断言相等整数(记忆条数(库), 3, "三条都落库");
    关闭记忆(库);
    返回 0;
}

函数 测_回忆命中与排序() : 整数 {
    变量 库: 整数 = _新库();
    记住(库, "事实", "项目仓库用的是 monorepo", "项目,仓库", 2);
    记住(库, "经验", "改仓库结构前先全量跑测试", "仓库,测试,重构", 5);
    // 双词命中：两条都含「仓库」，重要度 5 的经验排前面
    变量 块: 字符串 = 回忆(库, "仓库", 5);
    断言包含(块, "【经验】改仓库结构前先全量跑测试", "命中带类型标签的经验");
    断言包含(块, "【事实】项目仓库用的是 monorepo", "命中带类型标签的事实");
    断言相等整数(字符串::开始于(块, "-【经验】"), 1, "重要度高的经验排第一行");
    // 上限=1 只取重要度最高的一条
    变量 顶: 字符串 = 回忆(库, "仓库", 1);
    断言包含(顶, "经验", "上限1 → 只剩重要度最高的经验");
    断言不含(顶, "monorepo", "上限1 → 低重要度事实被截掉");
    // 逗号分隔多关键词：任一命中即可（含中文逗号归一）
    变量 多: 字符串 = 回忆(库, "不存在词，monorepo", 5);
    断言包含(多, "monorepo", "多关键词按 OR 匹配（中文逗号也认）");
    关闭记忆(库);
    返回 0;
}

函数 测_不命中与空关键词() : 整数 {
    变量 库: 整数 = _新库();
    记住(库, "事实", "用户在深圳工作", "用户,深圳", 4);
    断言相等整数(字符串::字节长度(回忆(库, "火星基地xyz", 5)), 0, "不命中返回空串");
    断言相等整数(字符串::字节长度(回忆(库, "", 5)), 0, "空关键词返回空串");
    断言相等整数(字符串::字节长度(回忆(库, " , ，", 5)), 0, "纯逗号/空白关键词返回空串");
    关闭记忆(库);
    返回 0;
}

函数 测_遗忘() : 整数 {
    变量 库: 整数 = _新库();
    变量 id1: 整数 = 记住(库, "事实", "临时事实", "临时", 1);
    记住(库, "偏好", "常驻偏好", "常驻", 3);
    断言相等整数(记忆条数(库), 2, "遗忘前 2 条");
    断言相等整数(遗忘(库, id1), 1, "遗忘返回删除条数 1");
    断言相等整数(记忆条数(库), 1, "遗忘后剩 1 条");
    断言相等整数(遗忘(库, id1), 0, "重复遗忘同 id 删除 0 条");
    断言相等整数(字符串::字节长度(回忆(库, "临时", 5)), 0, "被遗忘的条目不再被回忆");
    关闭记忆(库);
    返回 0;
}

函数 测_重开库持久化() : 整数 {
    变量 库: 整数 = _新库();
    记住(库, "偏好", "用户喜欢深色主题", "主题,深色", 4);
    关闭记忆(库);
    // 重开同一路径（打开记忆 的 IF NOT EXISTS 不应清掉旧数据）
    变量 库2: 整数 = 打开记忆(库路径);
    断言为真(_大于(库2, 0), "重开旧库成功");
    断言相等整数(记忆条数(库2), 1, "重开后数据还在");
    断言包含(回忆(库2, "主题", 5), "深色主题", "重开后可回忆");
    关闭记忆(库2);
    返回 0;
}

函数 测_SQL注入毒串无损() : 整数 {
    变量 库: 整数 = _新库();
    // 内容/关键词都带单引号 + 伪 SQL，应被当普通文本存取，不改写语句
    变量 毒: 字符串 = "小明说：'不错'; DROP TABLE 记忆; --";
    变量 id1: 整数 = 记住(库, "事实", 毒, "毒串,O'Brien", 4);
    断言为真(_大于(id1, 0), "毒串内容照常入库");
    断言相等整数(记忆条数(库), 1, "表没有被 DROP（条数可查）");
    // 原样取回（含单引号），且查询关键词本身带单引号也不崩
    断言包含(回忆(库, "毒串", 5), "DROP TABLE 记忆", "毒串内容原样取回");
    断言包含(回忆(库, "O'Brien", 5), "小明说", "带单引号的查询关键词照常匹配");
    // 再写一条验证库仍可用
    断言为真(_大于(记住(库, "偏好", "正常条目", "正常", 3), id1), "注入后库仍可正常写入");
    关闭记忆(库);
    返回 0;
}

函数 入口() {
    运行用例("记忆.建库与三类型记住", 测_建库与三类型记住);
    运行用例("记忆.回忆命中与排序", 测_回忆命中与排序);
    运行用例("记忆.不命中与空关键词", 测_不命中与空关键词);
    运行用例("记忆.遗忘", 测_遗忘);
    运行用例("记忆.重开库持久化", 测_重开库持久化);
    运行用例("记忆.SQL注入毒串无损", 测_SQL注入毒串无损);
    摘要并退出();
}
