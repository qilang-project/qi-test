// 记忆注入_集成测 — 用「假模型服务器」的 回显 回合验证 带记忆运行 的提示词注入。
//
// 前提：假模型服务器在 QI_FAKE_PORT 上跑，且轮到本测时脚本游标指向「回显|」回合
// （跑集成.sh 的脚本第 3 行；前一个套件恰好消费前 2 行）。
// 回显 = 服务器把收到的完整请求体当最终答复返回 —— 记忆块若被注入提示词，
// 必然出现在请求体 messages 里，直接对答复断言即可，全程无真 LLM。

包 主程序;

导入 测试::{运行用例, 摘要并退出, 断言包含};
导入 标准库.操作系统 作为 系统;
导入 标准库.字符串;
导入 标准库.输入输出 作为 IO;
导入 Harness::{模型配置, 大模型, 开启会话, 创建代理, 启用记忆, 带记忆运行, 关闭代理};
导入 Harness.记忆::{记住, 关闭记忆};

函数 测_记忆块注入提示词() : 整数 {
    变量 端口: 字符串 = 系统.获取环境变量("QI_FAKE_PORT");
    如果 (字符串::字节长度(端口) == 0) { 端口 = "41877"; }

    // 干净记忆库 + 一条高重要度偏好
    变量 库路径: 字符串 = "/tmp/qi记忆注入集成.db";
    如果 (IO.文件存在(库路径) == 1) { IO.删除文件(库路径); }

    变量 配置: 模型配置 = 大模型("http://127.0.0.1:" + 端口, "dummy-key", "fake-model");
    变量 会话: 整数 = 开启会话(配置);
    变量 代理值: 代理 = 创建代理("记忆代理", 会话);
    代理值 = 启用记忆(代理值, 库路径);
    记住(代理值.记忆库, "偏好", "用户要求汇报永远先给结论再给细节", "汇报,结论,周报", 5);

    // 假服务器本回合「回显」：答复 = 收到的请求体
    变量 回复: 字符串 = 带记忆运行(代理值, "帮我写一份周报", "周报,汇报");

    断言包含(回复, "相关记忆与过往经验", "记忆块标题被注入进发给模型的提示");
    断言包含(回复, "先给结论再给细节", "记忆内容出现在请求体里");
    断言包含(回复, "帮我写一份周报", "原始用户提示仍在");

    关闭记忆(代理值.记忆库);
    关闭代理(代理值);
    返回 0;
}

函数 入口() {
    运行用例("集成.记忆块注入提示词", 测_记忆块注入提示词);
    摘要并退出();
}
